# ============================================================
# Postfix 主配置 - 仅收件模式 (catch-all)
# ============================================================
smtpd_banner = $myhostname ESMTP
biff = no
append_dot_mydomain = no

# TLS (基础)
smtpd_use_tls = no

# 基本设置
myhostname = mail.123nhh.xyz
mydomain = 123nhh.xyz
myorigin = $mydomain
inet_interfaces = all
inet_protocols = ipv4

# 只收件，不中继
mydestination =
relay_domains =
local_transport = error:local delivery disabled
local_recipient_maps =

# 虚拟域名 catch-all：regexp map 支持精确域名和任意多级子域名，
# 直接通过 Postfix 内置 lmtp 客户端
# 把邮件送给常驻 mail-receiver daemon。
virtual_mailbox_domains = regexp:/etc/postfix/virtual_domains
virtual_transport = lmtp:unix:private/mail-receiver

# 限制
smtpd_recipient_restrictions =
    permit_mynetworks,
    reject_unauth_destination

# 性能优化
smtpd_client_connection_count_limit = 200
smtpd_client_connection_rate_limit = 600
default_process_limit = 500
maximal_queue_lifetime = 1d
bounce_queue_lifetime = 1d
message_size_limit = 10240000

# 并发
smtp_destination_concurrency_limit = 50
default_destination_concurrency_limit = 200
